{
  "id": "review-loop",
  "version": 1,
  "workflow_ref": "review-loop@1",
  "defaults": {
    "proposer_count": 4,
    "review_rounds": 5,
    "rebuttal_rounds": 5,
    "model_profile": "review-loop-default",
    "evidence_mode": "strict",
    "backend": "subprocess",
    "final_decider": "outer-entry-agent"
  },
  "overrides": {
    "proposer_count": {
      "exposure": "tunable",
      "min": 1,
      "max": 6
    },
    "review_rounds": {
      "exposure": "tunable",
      "min": 0,
      "max": 8
    },
    "rebuttal_rounds": {
      "exposure": "tunable",
      "min": 0,
      "max": 8
    },
    "model_profile": {
      "exposure": "tunable"
    },
    "evidence_mode": {
      "exposure": "tunable"
    }
  },
  "prompt_pack": {
    "role_contracts": {
      "coordinator": "prompts/contracts/review-loop/coordinator.md",
      "proposer": "prompts/contracts/review-loop/proposer.md"
    },
    "modules": [
      "prompts/modules/policies/evidence-strict.md",
      "prompts/modules/output/coordinator-summary.md"
    ]
  },
  "allowed_model_profiles": [
    "parallel-default",
    "review-loop-default",
    "review-loop-dashscope-ds-mm-qwen",
    "review-loop-dashscope-glm-mm27-qwen-kimi"
  ]
}
