{
  "id": "parallel",
  "version": 1,
  "roles": [
    "coordinator",
    "proposer"
  ],
  "parameters": {
    "proposer_count": {
      "type": "int",
      "default": 4,
      "min": 1,
      "max": 6
    }
  },
  "phases": [
    {
      "id": "propose",
      "kind": "primitive",
      "driver": "proposal_fanout",
      "emits": [
        "proposal"
      ],
      "advance_when": "all_required_submitted",
      "fallback": {
        "kind": "free_logic",
        "driver": "coordinator-fallback"
      }
    }
  ],
  "completion": {
    "done_when": "all_proposals_recorded",
    "final_decider": "outer-entry-agent"
  }
}
